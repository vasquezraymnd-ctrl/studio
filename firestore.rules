
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are identified by the string "admin" in their email.
    // email_verified check is removed as requested to allow immediate access for all registrations.
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // --- COLLECTION GROUP RULES (CRITICAL FOR GLOBAL LISTING) ---
    // These must be at the root level of documents to handle global collectionGroup queries.
    
    match /{path=**}/modules/{moduleId} {
      // Authenticated users can browse the global library.
      allow list, read: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      // Authenticated users can list all test banks.
      allow list, read: if isSignedIn();
    }

    match /{path=**}/progress/{progressId} {
      // Admins can see all student performance globally.
      // Students can list their own data (must filter by userId in the query).
      allow list: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // --- PATH-SPECIFIC RULES ---

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow create, update: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

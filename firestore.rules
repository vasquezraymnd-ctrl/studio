rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // 1. COLLECTION GROUP RULES - MUST BE AT THE TOP
    // These allow recursive queries like collectionGroup(db, 'modules')
    
    match /{path=**}/modules/{moduleId} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/progress/{progressId} {
      // Admins can see everything. 
      // Students can only see their own progress (requires .where("userId", "==", auth.uid) in the client query)
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // 2. STANDARD PATH RULES
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // User personal data
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
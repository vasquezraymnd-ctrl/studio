rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth checks
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower().matches('.*admin.*')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // COLLECTION GROUP RULES - MUST BE AT TOP
    // These allow recursive queries like collectionGroup(db, 'modules')
    match /{path=**}/modules/{moduleId} {
      allow read, list: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow read, list: if isSignedIn();
    }
    
    match /{path=**}/progress/{progressId} {
      // Admins can list all progress; students can only list their own (requires query filter)
      allow read, list: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // STANDARD PATH RULES
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // User personal data
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // --- COLLECTION GROUP RULES (Priority) ---
    // These must be defined at the top to correctly handle collectionGroup queries.
    
    match /{path=**}/modules/{moduleId} {
      allow read, list: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow read, list: if isSignedIn();
    }

    match /{path=**}/progress/{progressId} {
      // Admins can list all progress. Students can list their own via filtered query.
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // --- PATH-SPECIFIC RULES ---

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
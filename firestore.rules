rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // PRIMARY: Collection Group rules for global queries (Dashboard/Library)
    // These must allow 'list' for the query to succeed.
    match /{path=**}/modules/{moduleId} {
      allow read, list: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow read, list: if isSignedIn();
    }

    // SECONDARY: Subject-specific content rules
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // User personal data
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Admin registry
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
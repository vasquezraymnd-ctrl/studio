rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // --- COLLECTION GROUP RULES (MUST BE AT TOP) ---
    // These allow global queries (e.g., across all subjects)
    
    match /{path=**}/modules/{moduleId} {
      allow list, read: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow list, read: if isSignedIn();
    }

    match /{path=**}/progress/{progressId} {
      // Admins can list all. Students can only list if they filter by their own userId in the query.
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100 && resource.data.userId == request.auth.uid);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- PATH-SPECIFIC RULES ---

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
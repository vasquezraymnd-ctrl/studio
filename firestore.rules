
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are identified by the string "admin" in their email.
    // Removed email_verified requirement as requested.
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // --- COLLECTION GROUP RULES (CRITICAL FOR GLOBAL LISTING) ---
    // These rules handle queries that search across all subjects (e.g., global library).
    // They must be matched explicitly for list operations to succeed.
    
    match /{path=**}/modules/{moduleId} {
      allow list, read: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow list, read: if isSignedIn();
    }

    match /{path=**}/progress/{progressId} {
      // Admins can list and read all student performance globally.
      // Students can list their own data (must filter by userId in the query).
      allow list, read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Allow writing progress records
      allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // --- PATH-SPECIFIC RULES ---

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

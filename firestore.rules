rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Admins are identified by the string "admin" in their email.
    // Removed email_verified requirement as requested.
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.lower().matches('.*admin.*');
    }

    // --- COLLECTION GROUP RULES (REQUIRED FOR GLOBAL QUERIES) ---
    // These allow global listing across all subject-specific subcollections.
    // They must be matched via the {path=**} recursive wildcard.
    
    match /{path=**}/modules/{moduleId} {
      allow list, read: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow list, read: if isSignedIn();
    }

    match /{path=**}/progress/{progressId} {
      // Admins can list all student performance globally.
      // Students can only list their own progress data (must be filtered by userId in the query).
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- PATH-SPECIFIC RULES ---

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() { return request.auth != null; }
    
    // Admin check: either exists in admins collection or has 'admin' in their email
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower().matches('.*admin.*')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    // COLLECTION GROUP RULES
    // These must be defined at the root to allow collectionGroup() queries
    match /{path=**}/modules/{moduleId} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/assessments/{assessmentId} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/progress/{progressId} {
      // Admins can see all progress; students can see their own
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // STANDARD PATH RULES
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // User personal data rules
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /progress/{progressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
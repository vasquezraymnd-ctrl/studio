rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Admin check: either exists in admins collection or has 'admin' in their email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        (request.auth.token.email != null && request.auth.token.email.lower().matches('.*admin.*'))
      ); 
    }

    // Collection Group rules (Crucial for the Global Library page)
    // Allows collectionGroup(db, 'modules') queries to function across the entire database
    match /{path=**}/modules/{moduleId} {
      allow read: if isSignedIn();
    }

    // Standard subject-based path rules
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      
      match /assessments/{assessmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
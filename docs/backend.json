
{
  "entities": {
    "Subject": {
      "title": "Subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Module": {
      "title": "Module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "dateAdded": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "url"]
    },
    "Assessment": {
      "title": "Assessment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "totalItems": { "type": "number" },
        "difficulty": { "type": "string", "enum": ["Easy", "Moderate", "Hard", "Board Exam"] },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "q": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "a": { "type": "number", "description": "Index of correct option" },
              "rationale": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "title", "questions"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/subjects/{subjectId}": {
      "schema": "#/backend/entities/Subject",
      "description": "Top-level clinical subjects."
    },
    "/subjects/{subjectId}/modules/{moduleId}": {
      "schema": "#/backend/entities/Module",
      "description": "Study library materials for a subject."
    },
    "/subjects/{subjectId}/assessments/{assessmentId}": {
      "schema": "#/backend/entities/Assessment",
      "description": "100-item test banks for a subject."
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Admin registry for secure access."
    }
  }
}
